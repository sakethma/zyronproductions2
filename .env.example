# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Razorpay Payment Gateway Keys
# Sign up at https://razorpay.com to get these keys. 
# They are required to process real UPI and card payments.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Brevo (formerly Sendinblue) Email Integration (Required)
# Sign up at https://brevo.com to get an API key for sending confirmation emails via port 443 (HTTPS)
# This bypasses any outbound SMTP port restrictions (ports 25, 465, 587) on hosting providers like Render.
BREVO_API_KEY=
SMTP_FROM="Zyron Productions <tickets@zyronproduction.work.gd>"

# Authentication Secrets (Production defaults should be randomized using environment variables)
JWT_SECRET=zyron-super-secret-key-123
COOKIE_SECRET=zyron-secret-cookie-key-1337

# Cloud SQL PostgreSQL Database configuration
# Automatically provisioned and injected by AI Studio. Do not commit secrets here.
DATABASE_URL=
SQL_SSL=
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DB_NAME=
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=
